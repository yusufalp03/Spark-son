# Bu dosya örnektir. Gerçek değerleri proje kökündeki .env dosyasına yazın
# (.env git'e commitlenmez). Değerler Secrets Gradle Plugin ile derleme
# sırasında BuildConfig alanlarına işlenir.

# SPOTIFY_CLIENT_ID: Spotify Developer Dashboard'daki uygulamanızın Client ID'si
SPOTIFY_CLIENT_ID=MY_SPOTIFY_CLIENT_ID

# SPOTIFY_CLIENT_SECRET: Spotify Developer Client Secret
SPOTIFY_CLIENT_SECRET=MY_SPOTIFY_CLIENT_SECRET

# SUPABASE_URL: Supabase projenizin URL'i (https://<proje-id>.supabase.co)
SUPABASE_URL=https://proje-id.supabase.co

# SUPABASE_ANON_KEY: Supabase Public/Anon API anahtarı (Project Settings > API)
SUPABASE_ANON_KEY=senin-anon-keyin
